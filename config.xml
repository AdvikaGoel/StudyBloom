<?xml version='1.0' encoding='utf-8'?>\n<widget id=\"com.advikagoel.studybloom\" version=\"1.0.0\" versionCode=\"1\" \n        xmlns=\"http://www.w3.org/ns/widgets\" \n        xmlns:cdv=\"http://cordova.apache.org/ns/1.0\">\n    \n    <name>Study Bloom</name>\n    <description>\n        Study Bloom - Your cute, pastel-themed study companion with Japanese focus techniques.\n        Features Pomodoro Kai, flashcards, AI notes, exam tracker, calendar, and more!\n    </description>\n    <author email=\"advikagoel.ag11@gmail.com\" href=\"https://github.com/AdvikaGoel\">\n        Advika Goel\n    </author>\n\n    <!-- Preferences -->\n    <preference name=\"Orientation\" value=\"portrait\" />\n    <preference name=\"BackgroundColor\" value=\"0xFFFFFFFF\" />\n    <preference name=\"StatusBarBackgroundColor\" value=\"0xFFB3D9FF\" />\n    <preference name=\"StatusBarStyle\" value=\"blacktranslucent\" />\n    <preference name=\"Fullscreen\" value=\"false\" />\n    <preference name=\"ShowTitle\" value=\"true\" />\n    <preference name=\"FadeSplashScreenDuration\" value=\"3000\" />\n    <preference name=\"SplashShowOnlyFirstTime\" value=\"false\" />\n    <preference name=\"LogLevel\" value=\"DEBUG\" />\n\n    <!-- Plugins -->\n    <plugin name=\"cordova-plugin-statusbar\" spec=\"~2.4.2\" />\n    <plugin name=\"cordova-plugin-device\" spec=\"~2.0.2\" />\n    <plugin name=\"cordova-plugin-splashscreen\" spec=\"~5.0.2\" />\n    <plugin name=\"cordova-plugin-whitelist\" spec=\"~1.3.3\" />\n    <plugin name=\"cordova-plugin-inappbrowser\" spec=\"~3.0.0\" />\n\n    <!-- Content Security Policy -->\n    <allow-intent href=\"http://*/*\" />\n    <allow-intent href=\"https://*/*\" />\n    <allow-intent href=\"tel:*\" />\n    <allow-intent href=\"sms:*\" />\n    <allow-intent href=\"mailto:*\" />\n    <allow-intent href=\"geo:*\" />\n\n    <!-- Android specific preferences -->\n    <platform name=\"android\">\n        <icon src=\"res/icon/android/icon-36-ldpi.png\" density=\"ldpi\" />\n        <icon src=\"res/icon/android/icon-48-mdpi.png\" density=\"mdpi\" />\n        <icon src=\"res/icon/android/icon-72-hdpi.png\" density=\"hdpi\" />\n        <icon src=\"res/icon/android/icon-96-xhdpi.png\" density=\"xhdpi\" />\n        <icon src=\"res/icon/android/icon-144-xxhdpi.png\" density=\"xxhdpi\" />\n        <icon src=\"res/icon/android/icon-192-xxxhdpi.png\" density=\"xxxhdpi\" />\n\n        <splash src=\"res/screen/android/splash-land-ldpi.png\" density=\"land-ldpi\" />\n        <splash src=\"res/screen/android/splash-land-mdpi.png\" density=\"land-mdpi\" />\n        <splash src=\"res/screen/android/splash-land-hdpi.png\" density=\"land-hdpi\" />\n        <splash src=\"res/screen/android/splash-land-xhdpi.png\" density=\"land-xhdpi\" />\n\n        <splash src=\"res/screen/android/splash-port-ldpi.png\" density=\"port-ldpi\" />\n        <splash src=\"res/screen/android/splash-port-mdpi.png\" density=\"port-mdpi\" />\n        <splash src=\"res/screen/android/splash-port-hdpi.png\" density=\"port-hdpi\" />\n        <splash src=\"res/screen/android/splash-port-xhdpi.png\" density=\"port-xhdpi\" />\n\n        <allow-intent href=\"market:*\" />\n        <preference name=\"AndroidLaunchMode\" value=\"singleTop\" />\n        <preference name=\"AndroidPersistentFileLocation\" value=\"Compatibility\" />\n    </platform>\n\n    <!-- iOS specific preferences -->\n    <platform name=\"ios\">\n        <icon src=\"res/icon/ios/icon-40.png\" width=\"40\" height=\"40\" />\n        <icon src=\"res/icon/ios/icon-40@2x.png\" width=\"80\" height=\"80\" />\n        <icon src=\"res/icon/ios/icon-40@3x.png\" width=\"120\" height=\"120\" />\n        <icon src=\"res/icon/ios/icon-50.png\" width=\"50\" height=\"50\" />\n        <icon src=\"res/icon/ios/icon-50@2x.png\" width=\"100\" height=\"100\" />\n        <icon src=\"res/icon/ios/icon-60.png\" width=\"60\" height=\"60\" />\n        <icon src=\"res/icon/ios/icon-60@2x.png\" width=\"120\" height=\"120\" />\n        <icon src=\"res/icon/ios/icon-60@3x.png\" width=\"180\" height=\"180\" />\n        <icon src=\"res/icon/ios/icon-72.png\" width=\"72\" height=\"72\" />\n        <icon src=\"res/icon/ios/icon-72@2x.png\" width=\"144\" height=\"144\" />\n        <icon src=\"res/icon/ios/icon-76.png\" width=\"76\" height=\"76\" />\n        <icon src=\"res/icon/ios/icon-76@2x.png\" width=\"152\" height=\"152\" />\n        <icon src=\"res/icon/ios/icon-83.5@2x.png\" width=\"167\" height=\"167\" />\n        <icon src=\"res/icon/ios/icon-1024.png\" width=\"1024\" height=\"1024\" />\n\n        <splash src=\"res/screen/ios/Default~iphone.png\" width=\"320\" height=\"480\" />\n        <splash src=\"res/screen/ios/Default@2x~iphone.png\" width=\"640\" height=\"960\" />\n        <splash src=\"res/screen/ios/Default-Portrait~ipad.png\" width=\"768\" height=\"1024\" />\n        <splash src=\"res/screen/ios/Default-Portrait@2x~ipad.png\" width=\"1536\" height=\"2048\" />\n        <splash src=\"res/screen/ios/Default-Landscape~ipad.png\" width=\"1024\" height=\"768\" />\n        <splash src=\"res/screen/ios/Default-Landscape@2x~ipad.png\" width=\"2048\" height=\"1536\" />\n        <splash src=\"res/screen/ios/Default-568h@2x~iphone.png\" width=\"640\" height=\"1136\" />\n        <splash src=\"res/screen/ios/Default-667h.png\" width=\"750\" height=\"1334\" />\n        <splash src=\"res/screen/ios/Default-736h.png\" width=\"1242\" height=\"2208\" />\n\n        <preference name=\"target-device\" value=\"universal\" />\n        <preference name=\"prerendered-icon\" value=\"true\" />\n        <preference name=\"allow-inline-media-playback\" value=\"yes\" />\n        <preference name=\"webviewbounce\" value=\"false\" />\n    </platform>\n\n    <!-- Access rules -->\n    <access origin=\"*\" />\n    <allow-navigation href=\"*\" />\n\n</widget>\n